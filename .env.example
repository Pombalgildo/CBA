# ═══════════════════════════════════════════════════════
# VARIÁVEIS DE AMBIENTE - Convenção Baptista de Angola
# ═══════════════════════════════════════════════════════
# Copie este ficheiro para .env (local) ou configure estas
# variáveis no painel da Vercel (Settings > Environment Variables)

# ─── BASE DE DADOS (Supabase PostgreSQL) ───
# Crie uma conta gratuita em: https://supabase.com
# Dashboard > Project Settings > Database > Connection string
# Escolha "Transaction" mode URL
#
# Formato: postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres
DATABASE_URL="postgresql://postgres.xxxxxxxx:sua-palavra-passe@aws-0-regiao.pooler.supabase.com:6543/postgres"

# ─── SUPABASE STORAGE (Upload de imagens) ───
# No painel do Supabase: Project Settings > API
NEXT_PUBLIC_SUPABASE_URL="https://xxxxxxxx.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..."

# ─── SEGURANÇA ───
# Chave secreta para assinar tokens de administrador
# Gere uma com: openssl rand -hex 32
ADMIN_SECRET="altere-esta-chave-para-uma-string-aleatoria-longa-2026"
